# App
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database
DATABASE_URL=file:../data/bilo.sqlite

# JWT
JWT_SECRET=change-me-super-secret-key
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth (use real keys to enable real OAuth; mock auth is available otherwise)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# Frontend
FRONTEND_URL=http://localhost:5173

# Feature flags / providers
PAYMENT_PROVIDER=stripe_mock
AI_PROVIDER=mock
RECOMMENDATION_ENGINE=sqlite

# Optional standalone SQLite seeding
INSIDE_AIRBNB_CITIES=Mexico City,Rio De Janeiro
SQLITE_SEED_PATH=./data/seed/inside-airbnb.sqlite
SQLITE_SEED_LIMIT_PER_CITY=250
